# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/belka_ai

# Auth
JWT_SECRET=change-me

# BELKA integration
BELKA_CODER_API_BASE_URL=https://belka-coder-api-production.up.railway.app
BELKA_DEFAULT_IMAGE_MODEL=zimage

# Model providers
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
GEMINI_API_KEY=

# Search providers
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=

# Voice
POLLINATIONS_API_KEY=
POLLINATIONS_API_BASE_URL=https://gen.pollinations.ai
ELEVENLABS_API_KEY=
VOICE_PROVIDER_DEFAULT=pollinations
VOICE_DEFAULT_PRESET=jarvis_ru

# MCP runtime
MCP_DEFAULT_CWD=

# GitHub integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
